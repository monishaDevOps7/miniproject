# Dictionary to store student data
students = {}

# Add student
def add_student():
    name = input("Enter student name: ")
    courses = input("Enter courses (comma separated): ").split(",")

    # Clean spaces
    courses = [c.strip() for c in courses]

    students[name] = courses
    print(f" Student {name} added!")

# Update courses
def update_courses():
    name = input("Enter student name to update: ")

    if name in students:
        courses = input("Enter new courses (comma separated): ").split(",")
        courses = [c.strip() for c in courses]

        students[name] = courses
        print(f" Courses updated for {name}")
    else:
        print(" Student not found!")

# Display student details
def display_students():
    print("\n Student Details:")
    for name, courses in students.items():
        print(f"{name} → {', '.join(courses)}")

# Menu system
while True:
    print("\n====  Course Enrollment System ====")
    print("1. Add Student")
    print("2. Update Courses")
    print("3. Display Students")
    print("4. Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        add_student()
    elif choice == "2":
        update_courses()
    elif choice == "3":
        display_students()
    elif choice == "4":
        print(" Exiting...")
        break
    else:
        print(" Invalid choice!")
