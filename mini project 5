# Create an empty set to store unique visitors
visitors = set()

def add_visitor():
    name = input("Enter visitor name: ")
    
    # Add name to set (duplicates automatically ignored)
    visitors.add(name)
    print(f" {name} added successfully!")

def show_visitors():
    print("\n Unique Visitors List:")
    for v in visitors:
        print("-", v)
    
    print(f"\n Total Unique Visitors: {len(visitors)}")

# Menu system
while True:
    print("\n==== Visitor Counter ====")
    print("1. Add Visitor")
    print("2. Show Visitors")
    print("3. Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        add_visitor()
    elif choice == "2":
        show_visitors()
    elif choice == "3":
        print(" Exiting...")
        break
    else:
        print(" Invalid choice!")
